# ──────────────────────────────────────────────
# Social Assistant — environment variables
# Copy to .env and fill in real values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────

# Database (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/social_assistant

# Redis (job queue + cache)
REDIS_URL=redis://localhost:6379/0

# Token encryption key — AES-256-GCM
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
TOKEN_ENCRYPTION_KEY=replace_with_64_char_hex_string

# Google OAuth2 — from Google Cloud Console
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Must match what is registered in Google Cloud Console.
# The frontend callback page exchanges the code with the backend.
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# LLM provider — "gemini" (default, free tier) or "anthropic"
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic Claude API (only needed when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# JWT — use a long random string
JWT_SECRET=replace_with_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — JSON array of allowed origins
CORS_ORIGINS=["http://localhost:3000"]
